  <Flow>
    <Routine name="load_screen"/>
    <LoopInitiator loopType="TrialHandler" name="trials">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'song_file': 'audio/bbno1.mp3', 'trigger_value': 1.0}, {'song_file': 'audio/bbno2.mp3', 'trigger_value': 1.0}, {'song_file': 'audio/bbno3.mp3', 'trigger_value': 1.0}, {'song_file': 'audio/bbno4.mp3', 'trigger_value': 1.0}, {'song_file': 'audio/bbno5.mp3', 'trigger_value': 1.0}, {'song_file': 'audio/meme1.mp3', 'trigger_value': 2.0}, {'song_file': 'audio/meme2.mp3', 'trigger_value': 2.0}, {'song_file': 'audio/meme3.mp3', 'trigger_value': 2.0}, {'song_file': 'audio/meme4.mp3', 'trigger_value': 2.0}, {'song_file': 'audio/meme5.mp3', 'trigger_value': 2.0}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="COGS 189 song list.xlsx" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="code"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
